PORT=4000

# Choose MoMo environment: test (default) or production
MOMO_ENV=test

# Fill these from your MoMo developer console
MOMO_ACCESS_KEY=YOUR_ACCESS_KEY
MOMO_SECRET_KEY=YOUR_SECRET_KEY
MOMO_PARTNER_CODE=YOUR_PARTNER_CODE

# MoMo will POST payment result here
# Example for local testing: use ngrok or a public URL.
MOMO_IPN_URL=https://YOUR_DOMAIN.com/api/momo/ipn

# Redirect after MoMo payment page
MOMO_REDIRECT_URL=https://YOUR_DOMAIN.com/

# Optional
MOMO_STORE_NAME=AstralisMC
MOMO_STORE_ID=

